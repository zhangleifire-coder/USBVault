<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:USBVault.Client"
        Title="USB安全客户端"
        Height="480" Width="640"
        MinHeight="400" MinWidth="500"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#1976D2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="22,10"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#BDBDBD"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1565C0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#455A64"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#37474F"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#C62828"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#B71C1C"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Status Bar -->
        <Border x:Name="StatusBar" Grid.Row="0" Background="#D32F2F">
            <TextBlock x:Name="StatusBarText"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Left"
                       Margin="15,0,0,0"
                       Foreground="White"
                       FontSize="13"
                       FontWeight="SemiBold"/>
        </Border>

        <!-- Content Area -->
        <Grid Grid.Row="1" Background="#F5F5F5">

            <!-- ==================== USER MODE PANEL ==================== -->
            <StackPanel x:Name="UserModePanel" VerticalAlignment="Center" HorizontalAlignment="Center">

                <!-- Status Icon -->
                <TextBlock x:Name="StatusIcon"
                           Text="✗"
                           FontSize="80"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"/>

                <!-- Status Label -->
                <TextBlock x:Name="StatusLabel"
                           Text="未授权"
                           FontSize="30"
                           FontWeight="Bold"
                           Foreground="#333"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,16"/>

                <!-- Auth Count Badge -->
                <Border Background="#E3F2FD" CornerRadius="16"
                        HorizontalAlignment="Center"
                        Padding="20,8" Margin="0,0,0,35">
                    <TextBlock x:Name="AuthCountLabel"
                               Text="已授权 0/5 台电脑"
                               FontSize="14" Foreground="#1565C0"/>
                </Border>

                <!-- User Mode Buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="BtnOpenFile"
                            Content="打开文件"
                            Style="{StaticResource PrimaryButton}"
                            Click="BtnOpenFile_Click"/>
                    <Button x:Name="BtnAdminLogin"
                            Content="管理员登录"
                            Style="{StaticResource SecondaryButton}"
                            Click="BtnAdminLogin_Click"/>
                    <Button x:Name="BtnExit"
                            Content="退出"
                            Style="{StaticResource DangerButton}"
                            Click="BtnExit_Click"/>
                </StackPanel>

                <!-- Admin Login Panel (shown inline when logging in) -->
                <StackPanel x:Name="AdminLoginPanel" Margin="0,25,0,0" HorizontalAlignment="Center">
                    <TextBlock Text="管理员密码:" FontSize="13" Foreground="#555" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <PasswordBox x:Name="AdminPasswordBox" Width="220" Margin="0,0,8,0"
                                     KeyDown="AdminPasswordBox_KeyDown"/>
                        <Button x:Name="BtnConfirmLogin" Content="确认" Style="{StaticResource PrimaryButton}"
                                Click="BtnConfirmLogin_Click" MinWidth="80"/>
                        <Button x:Name="BtnCancelLogin" Content="取消" Style="{StaticResource SecondaryButton}"
                                Click="BtnCancelLogin_Click" MinWidth="80"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>

            <!-- ==================== ADMIN MODE PANEL ==================== -->
            <Grid x:Name="AdminModePanel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Row="0" Margin="20,15,20,8">
                    <TextBlock Text="管理面板" FontSize="22" FontWeight="Bold" Foreground="#1976D2"/>
                    <TextBlock x:Name="AdminAuthCountLabel" Text="当前授权: 0/5 台"
                               FontSize="13" Foreground="#666" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Machine List -->
                <DataGrid x:Name="MachinesDataGrid"
                          Grid.Row="1"
                          AutoGenerateColumns="False"
                          Margin="20,0,20,10"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          BorderBrush="#CCCCCC"
                          BorderThickness="1"
                          Background="White"
                          RowHeaderWidth="0"
                          SelectionChanged="MachinesDataGrid_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="机器编号" Binding="{Binding ShortId}" Width="*"/>
                        <DataGridTextColumn Header="注册时间" Binding="{Binding RegisteredAt, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Width="2*"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Admin Buttons -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="20,0,20,20" HorizontalAlignment="Left">
                    <Button Content="添加当前电脑" Style="{StaticResource PrimaryButton}" Click="BtnAddMachine_Click"/>
                    <Button x:Name="BtnRemoveMachine" Content="移除选中" Style="{StaticResource DangerButton}"
                            Click="BtnRemoveMachine_Click" IsEnabled="False"/>
                    <Button Content="修改密码" Style="{StaticResource SecondaryButton}" Click="BtnChangePassword_Click"/>
                    <Button Content="退出管理" Style="{StaticResource SecondaryButton}" Click="BtnLogout_Click"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>